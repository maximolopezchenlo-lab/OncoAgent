# ============================================================
# OncoAgent — .gitignore (Production Clean)
# ============================================================

# === Python Runtime ===
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
*.egg

# === Secrets & Environment ===
.env
.env.local
.env.*.local

# === Generated Data (regenerable via pipeline) ===
data/processed/
data/vector_db/
data/chroma_db/
data/synthetic/
data/raw/
data/final/
data/samples/
processed_data/
raw_data/
*.sqlite3

# === Model Weights & Checkpoints (too large for Git) ===
models/
checkpoints/
*.safetensors
*.bin
*.pt
*.pth
*.onnx
*.pickle
*.pkl

# === Scratch / Debug (internal development only) ===
scratch/
test_pipeline.py
test_ui.py
screenshot.py

# === Runtime Logs & PID Files ===
*.log
*.pid
ui_app.log
ui_app.pid

# === Duplicate Root-Level Files (canonical versions in logs/) ===
/paper_log.md
/paper_log.es.md
/paper_log.md.bak
/social_media_log.txt
/social_media_log.es.txt
/walkthrough.md
/walkthrough.es.md

# === Root-Level Duplicate Docs (canonical in docs/) ===
/oncoagent_master_directive.md

# === Internal AI & Tooling (not for judges) ===
.oncoagent/
.claude/
AGENTS.md
CLAUDE.md
docs/antigravity_rules.md
docs/oncoagent_master_directive.md

# === Social Media Logs (internal strategy) ===
logs/social_media_log*

# === IDE & Editor ===
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# === Node / Tooling ===
node_modules/
.gitnexus/
package-lock.json

# === External Docs (not part of codebase) ===
*.pdf.bak
AMD Developer Hackathon*.pdf
